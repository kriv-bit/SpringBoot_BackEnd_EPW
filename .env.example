# ==========================================================================
# Plantilla de variables de entorno para el backend (Spring Boot).
#
# Copia este archivo como ".env" y ajusta los valores a tu entorno.
#
# IMPORTANTE: Spring Boot NO lee archivos .env automáticamente. Lee
# VARIABLES DE ENTORNO del sistema operativo. Tienes dos opciones:
#
#   1) Exportar las variables antes de arrancar la app:
#        - PowerShell:  $env:CORS_ALLOWED_ORIGINS = "http://localhost:5173"
#        - Linux/Mac:   export CORS_ALLOWED_ORIGINS="http://localhost:5173"
#
#   2) Si quieres que lea el .env directamente, añade la dependencia
#      "me.paulschwarz:spring-dotenv" en el pom.xml.
#
# Si NO defines una variable, la app usa el valor por defecto indicado
# en application.properties (entre los ":" del placeholder).
# ==========================================================================

# --- CORS ---
# Orígenes (frontend) autorizados a llamar al backend desde un navegador.
# Varios separados por coma. Aquí va la IP/dominio de tu frontend, NO el del backend.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Base de datos (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/activities_db
DB_USERNAME=postgres
DB_PASSWORD=1234

# --- JWT ---
# Clave secreta de al menos 32 caracteres. CÁMBIALA en producción.
JWT_SECRET=clave-super-secreta-de-al-menos-32-caracteres-aqui
# Tiempo de expiración del token en milisegundos (86400000 = 24 horas).
JWT_EXPIRATION_MS=86400000
